{
  "name": "cypress",
  "version": "1.0.0",
  "description": "Sample Cypress project",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist .run",
    "build": "pnpm clean && tsc",
    "test": "pnpm build && cypress run --browser chrome --headless",
    "test:chrome": "cypress run --browser chrome --spec \"src/features/sauce-demo-login.feature\" --headless",
    "test:firefox": "cypress run --browser firefox --spec \"src/features/saucedemo.feature\" --headless",
    "report": "node dist/cucumber-html-report.js"
  },
  "author": "Wasiq Bhamla",
  "license": "MIT",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@mchr/tsconfig": "workspace:*",
    "@types/node": "^26.0.0",
    "cypress": "^15.18.0",
    "multiple-cucumber-html-reporter": "workspace:*",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dayjs": "^1.11.20"
  }
}
