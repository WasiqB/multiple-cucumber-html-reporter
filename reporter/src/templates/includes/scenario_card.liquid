{% assign scenario_status = "passed" %}
{% if scenario.failed > 0 %}
    {% assign scenario_status = "failed" %}
{% elsif scenario.ambiguous > 0 %}
    {% assign scenario_status = "ambiguous" %}
{% elsif scenario.notDefined > 0 %}
    {% assign scenario_status = "undefined" %}
{% elsif scenario.pending > 0 %}
    {% assign scenario_status = "pending" %}
{% elsif scenario.skipped > 0 %}
    {% assign scenario_status = "skipped" %}
{% endif %}

<div class="rounded-xl border bg-card text-card-foreground shadow overflow-hidden scenario-card" data-status="{{ scenario_status }}">
    <button class="w-full text-left px-4 md:px-6 py-4 flex items-center justify-between hover:bg-muted/50 transition-colors" onclick="this.nextElementSibling.classList.toggle('hidden')">
        <div class="flex items-center gap-3 overflow-hidden">
            
            {% if scenario_status == "passed" %}
            <i class="fa-solid fa-circle-check text-xl md:text-2xl shrink-0 text-status-passed"></i>
            {% elsif scenario_status == "failed" %}
            <i class="fa-solid fa-circle-xmark text-xl md:text-2xl shrink-0 text-status-failed"></i>
            {% elsif scenario_status == "ambiguous" %}
            <i class="fa-solid fa-bolt text-xl md:text-2xl shrink-0 text-status-ambiguous"></i>
            {% elsif scenario_status == "undefined" %}
            <i class="fa-solid fa-circle-question text-xl md:text-2xl shrink-0 text-status-undefined"></i>
            {% elsif scenario_status == "pending" %}
            <i class="fa-solid fa-circle-minus text-xl md:text-2xl shrink-0 text-status-pending"></i>
            {% else %}
            <i class="fa-solid fa-circle-right text-xl md:text-2xl shrink-0 text-status-skipped"></i>
            {% endif %}

            <div class="truncate">
                <h4 class="font-bold text-sm md:text-base truncate">{{ scenario.name }}</h4>
                {% if scenario.tags.size > 0 %}
                <div class="flex flex-wrap gap-1 mt-0.5">
                    {% for tag in scenario.tags %}
                    <span class="text-[9px] md:text-[10px] font-medium text-muted-foreground">{{ tag.name }}</span>
                    {% endfor %}
                </div>
                {% endif %}
                {% if scenario.description and scenario.description != "" %}
                <div class="mt-2 text-xs text-muted-foreground line-clamp-2">{{ scenario.description }}</div>
                {% endif %}
            </div>
        </div>
        <div class="flex items-center gap-2 md:gap-4 shrink-0 ml-2">
            <span class="font-mono text-[10px] md:text-xs text-muted-foreground">{{ scenario.time }}</span>
            <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
    </button>
    <div class="hidden border-t divide-y divide-border">
        {% if scenario.description and scenario.description != "" %}
        <div class="px-6 py-3 bg-muted/10 border-b">
            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1">Description</p>
            <div class="text-sm text-foreground/80 leading-relaxed whitespace-pre-wrap">{{ scenario.description }}</div>
        </div>
        {% endif %}

        {% for step in scenario.steps %}
        <div class="px-6 py-4 bg-muted/20">
            <div class="flex items-start justify-between">
                <div class="flex items-start gap-3 w-full">
                        {% if step.result.status == "passed" %}
                        <i class="fa-solid fa-circle-check mt-0.5 shrink-0 text-status-passed"></i>
                        {% elsif step.result.status == "failed" %}
                        <i class="fa-solid fa-circle-xmark mt-0.5 shrink-0 text-status-failed"></i>
                        {% elsif step.result.status == "ambiguous" %}
                        <i class="fa-solid fa-bolt mt-0.5 shrink-0 text-status-ambiguous"></i>
                        {% elsif step.result.status == "undefined" %}
                        <i class="fa-solid fa-circle-question mt-0.5 shrink-0 text-status-undefined"></i>
                        {% elsif step.result.status == "pending" %}
                        <i class="fa-solid fa-circle-minus mt-0.5 shrink-0 text-status-pending"></i>
                        {% else %}
                        <i class="fa-solid fa-circle-right mt-0.5 shrink-0 text-status-skipped"></i>
                        {% endif %}
                        <div class="w-full">
                        <p class="text-sm">
                            <span class="font-bold text-foreground">{{ step.keyword }}</span>
                            <span>{{ step.name }}</span>
                        </p>
                        <p class="text-[10px] text-muted-foreground mt-1 font-mono">{{ step.time }}</p>

                        {% if step.arguments %}
                            {% for argument in step.arguments %}
                                {% if argument.rows %}
                                    <div class="mt-3 overflow-x-auto rounded-lg border border-border shadow-sm bg-background/50">
                                        <table class="w-full text-[11px] text-left border-collapse">
                                            <thead>
                                                <tr class="bg-muted/50 border-b border-border">
                                                    {% for cell in argument.rows[0].cells %}
                                                    <th class="px-3 py-2 font-bold text-foreground whitespace-nowrap">{{ cell }}</th>
                                                    {% endfor %}
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-border">
                                                {% for row in argument.rows offset:1 %}
                                                <tr class="hover:bg-muted/30 transition-colors">
                                                    {% for cell in row.cells %}
                                                    <td class="px-3 py-2 text-muted-foreground whitespace-nowrap">{{ cell }}</td>
                                                    {% endfor %}
                                                </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        {% endif %}

                        {% if step.restWireData and step.restWireData != "" %}
                            <div class="mt-3 p-3 bg-muted/30 border border-border rounded-lg text-[11px] font-mono text-muted-foreground/80 overflow-x-auto whitespace-pre-wrap leading-relaxed">
                                {{ step.restWireData }}
                            </div>
                        {% endif %}

                        {% if step.result.error_message and step.result.error_message != "" %}
                        <div class="mt-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-[11px] font-mono text-red-600 dark:text-red-400 overflow-hidden line-clamp-6 whitespace-pre-wrap cursor-pointer modal-trigger hover:bg-red-500/20 transition-colors group relative"
                             data-attachment-type="error"
                             data-attachment-name="Error details"
                             data-attachment-content="{{ step.result.error_message | escape }}">
                            <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </div>
                            {{ step.result.error_message | escape | strip }}
                        </div>
                        {% endif %}
                        
                        {% assign has_attachments = false %}
                        {% if step.attachments.size > 0 or step.image.size > 0 or step.text.size > 0 or step.video.size > 0 or step.json.size > 0 or step.html.size > 0 %}
                            {% assign has_attachments = true %}
                        {% endif %}

                        {% if has_attachments %}
                        <div class="mt-3 space-y-2 bg-background/50 p-3 rounded border border-muted">
                            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Attachments</p>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                {% for item in step.image %}
                                <div class="flex items-center justify-between gap-2 bg-background p-2 rounded border border-muted/50 text-xs hover:border-primary/50 transition-colors cursor-pointer modal-trigger" 
                                        data-attachment-type="screenshot" 
                                        data-attachment-name="Screenshot - {{ forloop.index }}"
                                        data-attachment-content="{{ item }}">
                                    <div class="flex items-center gap-2">
                                        <svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        <span class="font-medium cursor-pointer">Screenshot {{ forloop.index }}</span>
                                    </div>
                                    <svg class="h-3 w-3 text-muted-foreground outline-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </div>
                                {% endfor %}

                                {% for item in step.text %}
                                <div class="flex items-center justify-between gap-2 bg-background p-2 rounded border border-muted/50 text-xs hover:border-primary/50 transition-colors cursor-pointer modal-trigger" 
                                        data-attachment-type="log" 
                                        data-attachment-name="Log - {{ forloop.index }}"
                                        data-attachment-content="{{ item | escape }}">
                                    <div class="flex items-center gap-2">
                                        <svg class="h-4 w-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                        <span class="font-medium cursor-pointer">Log {{ forloop.index }}</span>
                                    </div>
                                    <svg class="h-3 w-3 text-muted-foreground outline-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </div>
                                {% endfor %}

                                {% for item in step.video %}
                                <div class="flex items-center justify-between gap-2 bg-background p-2 rounded border border-muted/50 text-xs hover:border-primary/50 transition-colors cursor-pointer modal-trigger" 
                                        data-attachment-type="video" 
                                        data-attachment-name="Video - {{ forloop.index }}"
                                        data-attachment-content="{{ item }}">
                                    <div class="flex items-center gap-2">
                                        <svg class="h-4 w-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        <span class="font-medium cursor-pointer">Video {{ forloop.index }}</span>
                                    </div>
                                    <svg class="h-3 w-3 text-muted-foreground outline-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </div>
                                {% endfor %}

                                {% for item in step.json %}
                                <div class="flex items-center justify-between gap-2 bg-background p-2 rounded border border-muted/50 text-xs hover:border-primary/50 transition-colors cursor-pointer modal-trigger" 
                                        data-attachment-type="log" 
                                        data-attachment-name="JSON - {{ forloop.index }}"
                                        data-attachment-content="{{ item | json | escape }}">
                                    <div class="flex items-center gap-2">
                                        <svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                                        <span class="font-medium cursor-pointer">JSON {{ forloop.index }}</span>
                                    </div>
                                    <svg class="h-3 w-3 text-muted-foreground outline-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </div>
                                {% endfor %}

                                {% for attachment in step.attachments %}
                                <div class="flex items-center justify-between gap-2 bg-background p-2 rounded border border-muted/50 text-xs hover:border-primary/50 transition-colors cursor-pointer modal-trigger" 
                                        data-attachment-type="{{ attachment.type }}" 
                                        data-attachment-name="Attachment - {{ forloop.index }}"
                                        data-attachment-content="{{ attachment.data }}">
                                    <div class="flex items-center gap-2">
                                        <svg class="h-4 w-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        <span class="font-medium cursor-pointer">Attachment {{ forloop.index }}</span>
                                    </div>
                                    <svg class="h-3 w-3 text-muted-foreground outline-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                        </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
