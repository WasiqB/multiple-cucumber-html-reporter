<div class="flex flex-wrap items-center gap-3 md:gap-4 text-sm text-muted-foreground">
    {% if feature.device %}
    {% assign device = feature.device | downcase %}
    <span class="flex items-center gap-1.5" title="{{ feature.device }}">
        <i class="{% if device contains 'iphone' or device contains 'android' or device contains 'mobile' %}fa-solid fa-mobile-screen-button{% elsif device contains 'tablet' or device contains 'ipad' %}fa-solid fa-tablet-screen-button{% else %}fa-solid fa-desktop{% endif %} text-primary text-base"></i>
    </span>
    {% endif %}
    {% if feature.os %}
    {% assign os = feature.os | downcase %}
    <span class="flex items-center gap-1.5" title="{{ feature.os }}">
        <i class="{% if os contains 'windows' %}fa-brands fa-windows{% elsif os contains 'osx' or os contains 'ios' or os contains 'macos' or os contains 'mac' %}fa-brands fa-apple{% elsif os contains 'android' %}fa-brands fa-android{% elsif os contains 'linux' or os contains 'ubuntu' %}fa-brands fa-linux{% else %}fa-solid fa-laptop-code{% endif %} text-primary text-base"></i>
    </span>
    {% endif %}
    {% if feature.browser %}
    {% assign browser = feature.browser | downcase %}
    <span class="flex items-center gap-1.5" title="{{ feature.browser }}">
        <i class="{% if browser contains 'chrome' %}fa-brands fa-chrome{% elsif browser contains 'firefox' %}fa-brands fa-firefox{% elsif browser contains 'safari' %}fa-brands fa-safari{% elsif browser contains 'edge' %}fa-brands fa-edge{% else %}fa-solid fa-globe{% endif %} text-primary text-base"></i>
    </span>
    {% endif %}
    {% if feature.app and feature.app != "" %}
    <span class="flex items-center gap-1.5" title="{{ feature.app }}">
        <i class="fa-solid fa-cube text-primary text-base"></i>
    </span>
    {% endif %}

    {% comment %} Cloud / Local platform badge {% endcomment %}
    {% assign exec_platform = feature.executionPlatform | default: "local" %}
    {% if exec_platform == "browserstack" %}
    <span class="flex items-center gap-1.5 rounded-full bg-orange-500/10 px-2.5 py-1 border border-orange-500/30" title="Running on BrowserStack">
        <i class="fa-solid fa-cloud text-[#e1660a] text-sm"></i>
    </span>
    {% elsif exec_platform == "testmu" %}
    <span class="flex items-center gap-1.5 rounded-full bg-indigo-500/10 px-2.5 py-1 border border-indigo-500/30" title="Running on TestMu AI">
        <i class="fa-solid fa-cloud text-indigo-500 text-sm"></i>
    </span>
    {% else %}
    <span class="flex items-center gap-1.5 rounded-full bg-muted/50 px-2.5 py-1 border border-border" title="Running locally">
        <i class="fa-solid fa-computer text-primary text-sm"></i>
    </span>
    {% endif %}

    {% if feature.uri and feature.uri != "" %}
    <span class="flex items-center gap-1.5 min-w-0" title="{{ feature.uri }}">
        <i class="fa-solid fa-file-code text-primary text-base shrink-0"></i>
        <span class="text-xs font-mono text-muted-foreground truncate max-w-[200px]">{{ feature.uri }}</span>
    </span>
    {% endif %}
    {% if feature.metadata %}
        {% for item in feature.metadata %}
        {% if item.value %}
        <span class="flex items-center gap-1.5" title="{{ item.label }}: {{ item.value }}">
            <i class="fa-solid fa-circle-info text-primary text-base shrink-0"></i>
            <span class="text-xs text-foreground font-medium">{{ item.value }}</span>
        </span>
        {% endif %}
        {% endfor %}
    {% endif %}
</div>
