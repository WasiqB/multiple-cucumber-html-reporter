<div class="rounded-xl border bg-card text-card-foreground shadow overflow-hidden" id="features-table-container">
    <div class="px-6 py-4 border-b flex flex-col md:flex-row md:items-center justify-between gap-4">
        <h3 class="text-lg font-semibold whitespace-nowrap">Features Overview</h3>
        <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
            <div class="relative flex-1 md:w-64">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-muted-foreground">
                    <i class="fa-solid fa-magnifying-glass text-xs"></i>
                </span>
                <input type="text" id="feature-search" placeholder="Search features..." 
                        class="w-full h-9 pl-9 pr-4 rounded-md border border-input bg-background text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 transition-shadow shadow-sm">
            </div>
            <!-- Tag Filter Dropdown -->
            <div class="relative w-full md:w-56" id="feature-tag-filter-container">
                <button type="button" id="feature-tag-filter-button" 
                        class="flex items-center justify-between w-full h-9 px-3 rounded-md border border-input bg-background text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-shadow shadow-sm cursor-pointer">
                    <span class="truncate text-muted-foreground text-xs" id="feature-tag-filter-label">Filter by tags...</span>
                    <i class="fa-solid fa-chevron-down text-[10px] text-muted-foreground ml-2"></i>
                </button>
                <div id="feature-tag-filter-dropdown" 
                     class="hidden absolute left-0 md:left-auto md:right-0 mt-1 w-full md:w-56 rounded-md border border-border bg-card text-card-foreground shadow-md z-50 max-h-60 overflow-y-auto p-1.5 space-y-1">
                    <!-- Dynamic tag options injected via JS -->
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-muted-foreground whitespace-nowrap">Show:</span>
                <select id="records-per-page" 
                        class="h-9 px-2 rounded-md border border-input bg-background text-xs ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 transition-shadow shadow-sm min-w-[70px]">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="bg-muted text-muted-foreground uppercase text-xs font-semibold">
                <tr>
                    <th class="px-4 md:px-6 py-3 cursor-pointer hover:text-foreground transition-colors group">
                        <div class="flex items-center gap-1.5">
                            Feature Name
                            <i class="fa-solid fa-sort opacity-30 group-hover:opacity-100 text-[10px]"></i>
                        </div>
                    </th>
                    <th class="px-4 md:px-6 py-3">Environment</th>
                    <th class="px-4 md:px-6 py-3 cursor-pointer hover:text-foreground transition-colors group">
                        <div class="flex items-center gap-1.5">
                            Steps status
                            <i class="fa-solid fa-sort opacity-30 group-hover:opacity-100 text-[10px]"></i>
                        </div>
                    </th>
                    <th class="px-4 md:px-6 py-3 text-right cursor-pointer hover:text-foreground transition-colors group">
                        <div class="flex items-center justify-end gap-1.5">
                            Pass %
                            <i class="fa-solid fa-sort opacity-30 group-hover:opacity-100 text-[10px]"></i>
                        </div>
                    </th>
                </tr>
            </thead>
            <tbody id="features-table-body" class="divide-y divide-border">
                {% comment %} Initial render by Liquid for SEO/no-JS {% endcomment %}
                {% for feature in data.features limit: 10 %}
                <tr class="hover:bg-muted/50 transition-colors">
                    <td class="px-4 md:px-6 py-4 whitespace-nowrap md:whitespace-normal min-w-[200px]">
                        <a href="features/{{ feature.id }}.html" class="font-medium text-primary hover:underline">
                            {{ feature.name }}
                        </a>
                        <div class="flex flex-wrap gap-1 mt-1">
                            {% for tag in feature.tags %}
                            <span class="inline-flex items-center rounded-full bg-secondary px-2 py-0.5 text-[10px] font-medium text-secondary-foreground">
                                {{ tag.name }}
                            </span>
                            {% endfor %}
                        </div>
                    </td>
                    <td class="px-4 md:px-6 py-4 whitespace-nowrap">
                        {% assign device = feature.device | default: feature.metadata.device | default: "desktop" | downcase %}
                        {% assign os = feature.os | default: feature.metadata.platform.name | default: "" | downcase %}
                        {% assign browser = feature.browser | default: feature.metadata.browser.name | default: "" | downcase %}
                        {% assign exec_platform = feature.executionPlatform | default: "local" %}
                        
                        <div class="flex items-center gap-2.5 text-muted-foreground">
                            {% comment %} Device icon {% endcomment %}
                            <span title="{{ feature.device | default: 'Desktop' }}">
                                <i class="{% if device contains 'iphone' or device contains 'android' or device contains 'mobile' %}fa-solid fa-mobile-screen-button{% elsif device contains 'tablet' or device contains 'ipad' %}fa-solid fa-tablet-screen-button{% else %}fa-solid fa-desktop{% endif %} text-base"></i>
                            </span>
                            {% comment %} OS icon {% endcomment %}
                            {% if os != "" %}
                            <span title="{{ feature.os | default: feature.metadata.platform.name }}">
                                <i class="{% if os contains 'windows' %}fa-brands fa-windows{% elsif os contains 'osx' or os contains 'darwin' or os contains 'ios' or os contains 'macos' or os contains 'mac' %}fa-brands fa-apple{% elsif os contains 'android' %}fa-brands fa-android{% elsif os contains 'linux' or os contains 'ubuntu' %}fa-brands fa-linux{% else %}fa-solid fa-laptop-code{% endif %} text-base"></i>
                            </span>
                            {% endif %}
                            {% comment %} Browser icon {% endcomment %}
                            {% if browser != "" %}
                            <span title="{{ feature.browser | default: feature.metadata.browser.name }}">
                                <i class="{% if browser contains 'chrome' %}fa-brands fa-chrome{% elsif browser contains 'firefox' %}fa-brands fa-firefox{% elsif browser contains 'safari' %}fa-brands fa-safari{% elsif browser contains 'edge' %}fa-brands fa-edge{% else %}fa-solid fa-globe{% endif %} text-base"></i>
                            </span>
                            {% endif %}
                            {% comment %} Cloud platform divider + icon {% endcomment %}
                            {% if exec_platform != "local" %}
                            {% if exec_platform == "browserstack" %}
                            <span title="BrowserStack" class="text-[#e1660a]">
                                <i class="fa-solid fa-cloud text-base"></i>
                            </span>
                            {% elsif exec_platform == "testmu" %}
                            <span title="TestMu AI" class="text-indigo-500">
                                <i class="fa-solid fa-cloud text-base"></i>
                            </span>
                            {% endif %}
                            {% else %}
                            <span title="Local machine">
                                <i class="fa-solid fa-computer text-base"></i>
                            </span>
                            {% endif %}
                        </div>
                    </td>
                    <td class="px-4 md:px-6 py-4 min-w-[240px]">
                        <div class="flex h-2 w-full overflow-hidden rounded-full bg-secondary">
                            {% if feature.scenarios.passed > 0 %}
                            <div class="h-full bg-status-passed" style="width: {{ feature.scenarios.passed | plus: 0.0 | divided_by: feature.scenarios.total | times: 100 }}%"></div>
                            {% endif %}
                            {% if feature.scenarios.failed > 0 %}
                            <div class="h-full bg-status-failed" style="width: {{ feature.scenarios.failed | plus: 0.0 | divided_by: feature.scenarios.total | times: 100 }}%"></div>
                            {% endif %}
                            {% if feature.scenarios.ambiguous > 0 %}
                            <div class="h-full bg-status-ambiguous" style="width: {{ feature.scenarios.ambiguous | plus: 0.0 | divided_by: feature.scenarios.total | times: 100 }}%"></div>
                            {% endif %}
                            {% if feature.scenarios.notDefined > 0 %}
                            <div class="h-full bg-status-undefined" style="width: {{ feature.scenarios.notDefined | plus: 0.0 | divided_by: feature.scenarios.total | times: 100 }}%"></div>
                            {% endif %}
                            {% if feature.scenarios.pending > 0 %}
                            <div class="h-full bg-status-pending" style="width: {{ feature.scenarios.pending | plus: 0.0 | divided_by: feature.scenarios.total | times: 100 }}%"></div>
                            {% endif %}
                            {% if feature.scenarios.skipped > 0 %}
                            <div class="h-full bg-status-skipped" style="width: {{ feature.scenarios.skipped | plus: 0.0 | divided_by: feature.scenarios.total | times: 100 }}%"></div>
                            {% endif %}
                        </div>
                        <div class="mt-1 flex flex-wrap gap-x-2 gap-y-0.5 text-[10px] font-medium uppercase">
                            <span class="text-status-passed">{{ feature.passed }} Passed</span>
                            <span class="text-status-failed">{{ feature.failed }} Failed</span>
                            {% if feature.ambiguous > 0 %}<span class="text-status-ambiguous">{{ feature.ambiguous }} Ambiguous</span>{% endif %}
                            {% if feature.notDefined > 0 %}<span class="text-status-undefined">{{ feature.notDefined }} Not Defined</span>{% endif %}
                            {% if feature.pending > 0 %}<span class="text-status-pending">{{ feature.pending }} Pending</span>{% endif %}
                            <span class="text-status-skipped">{{ feature.skipped }} Skipped</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                         {% assign total = feature.passed | plus: feature.failed | plus: feature.ambiguous | plus: feature.notDefined | plus: feature.pending | plus: feature.skipped %}
                         {% if total > 0 %}
                            {% assign passPercentage = feature.passed | times: 100 | divided_by: total %}
                         {% else %}
                            {% assign passPercentage = 0 %}
                         {% endif %}
                         <div class="inline-flex items-center justify-end relative h-12 w-12">
                            <svg class="h-12 w-12 transform -rotate-90">
                              <circle class="text-muted/20" stroke-width="3" stroke="currentColor" fill="transparent" r="20" cx="24" cy="24" />
                              <circle class="text-status-passed transition-all duration-500 ease-out" stroke-width="3" 
                                stroke-dasharray="125.6" 
                                stroke-dashoffset="{{ 100 | minus: passPercentage | times: 1.256 }}" 
                                stroke-linecap="round" stroke="currentColor" fill="transparent" r="20" cx="24" cy="24" />
                            </svg>
                            <span class="absolute inset-0 flex items-center justify-center text-[10px] font-bold">{{ passPercentage }}%</span>
                         </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div id="no-features-message" class="hidden py-12 text-center bg-muted/20 border-t border-border">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-muted mb-4">
            <i class="fa-solid fa-magnifying-glass text-muted-foreground"></i>
        </div>
        <h4 class="text-sm font-semibold text-foreground">No feature found</h4>
        <p class="text-xs text-muted-foreground mt-1">Try adjusting your filters or search terms.</p>
    </div>

    <!-- Pagination -->
    <div class="px-6 py-4 border-t flex items-center justify-between text-xs text-muted-foreground bg-muted/20">
        <div>
            Showing <span id="showing-start" class="font-bold text-foreground">1</span> to <span id="showing-end" class="font-bold text-foreground">10</span> of <span id="total-records" class="font-bold text-foreground">{{ data.features.size }}</span> entries
        </div>
        <div class="flex items-center gap-1" id="pagination-controls">
            <button id="prev-page" disabled class="h-8 w-8 flex items-center justify-center rounded border border-transparent text-foreground hover:bg-muted hover:border-border transition-all disabled:opacity-30 disabled:cursor-not-allowed">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div id="page-numbers" class="flex items-center gap-1">
                <!-- Page buttons will be injected here -->
            </div>
            <button id="next-page" {% if data.features.size <= 10 %}disabled{% endif %} class="h-8 w-8 flex items-center justify-center rounded border border-transparent text-foreground hover:bg-muted hover:border-border transition-all disabled:opacity-30 disabled:cursor-not-allowed">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>
</div>
