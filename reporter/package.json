{
  "name": "multiple-cucumber-html-reporter",
  "version": "3.10.0",
  "description": "Generate beautiful Cucumber.js reports for multiple instances (browsers / devices)",
  "type": "module",
  "keywords": [
    "cucumber",
    "html",
    "test report",
    "multiple-cucumber-html-reporter",
    "html report",
    "json to html"
  ],
  "main": "dist/generate-report.js",
  "types": "dist/generate-report.d.ts",
  "exports": {
    ".": {
      "types": "./dist/generate-report.d.ts",
      "import": "./dist/generate-report.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "scripts": {
    "release": "release-it --ci",
    "prebuild": "pnpm generate:css && pnpm generate:css:min",
    "build": "tsc && cp -r src/templates dist/templates",
    "postbuild": "mkdir -p dist/test/unit && cp src/test/*.css dist/test/ && sed 's|src/test|dist/test|g' src/test/unit/jasmine.json > dist/test/unit/jasmine.json",
    "test": "node ./dist/test/test.js",
    "unit.test": "jasmine JASMINE_CONFIG_PATH=dist/test/unit/jasmine.json",
    "unit.test.coverage": "JASMINE_CONFIG_PATH=dist/test/unit/jasmine.json c8 jasmine",
    "generate:css": "npx @tailwindcss/cli -i ./src/templates/styles/main.css -o ./src/templates/assets/css/styles.css",
    "generate:css:min": "npx @tailwindcss/cli -i ./src/templates/styles/main.css -o ./src/templates/assets/css/styles.min.css --minify"
  },
  "repository": {
    "url": "https://github.com/WasiqB/multiple-cucumber-html-reporter"
  },
  "author": "WasiqB",
  "bugs": {
    "url": "https://github.com/WasiqB/multiple-cucumber-html-reporter/issues"
  },
  "funding": {
    "type": "GitHub Sponsor",
    "url": "https://github.com/sponsors/WasiqB"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://github.com/WasiqB/multiple-cucumber-html-reporter#readme",
  "dependencies": {
    "find": "^0.3.0",
    "fs-extra": "^11.3.5",
    "jsonfile": "^6.2.1",
    "liquidjs": "^10.25.7",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "open": "^11.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@mchr/tsconfig": "workspace:*",
    "@release-it-plugins/lerna-changelog": "^8.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jasmine": "^6.0.0",
    "@types/jsonfile": "^6.1.4",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "c8": "^11.0.0",
    "jasmine": "^6.2.0",
    "lerna-changelog": "^2.2.0",
    "release-it": "^19.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
