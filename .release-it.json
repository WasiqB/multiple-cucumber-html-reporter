{
  "$schema": "https://unpkg.com/release-it@latest/schema/release-it.json",
  "plugins": {
    "@release-it-plugins/lerna-changelog": {
      "infile": "CHANGELOG.md",
      "prettier": true
    }
  },
  "hooks": {
    "before:npm:release": "cp README.md reporter/ && cp LICENSE reporter/",
    "after:npm:release": "rm reporter/README.md reporter/LICENSE"
  },
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore: release v${version}",
    "commit": true,
    "tag": true,
    "push": true,
    "commitArgs": ["-S", "--no-verify"],
    "tagArgs": ["-s"],
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": true,
    "tokenRef": "PUSH_TOKEN",
    "discussionCategoryName": "Announcements",
    "comments": {
      "submit": true,
      "issue": ":rocket: _This issue has been resolved in v${version}. See [${releaseName}](${releaseUrl}) for release notes._",
      "pr": ":rocket: _This pull request is included in v${version}. See [${releaseName}](${releaseUrl}) for release notes._"
    }
  },
  "npm": {
    "publishPackageManager": "pnpm",
    "publishPath": "reporter",
    "versionArgs": ["--prefix", "reporter"],
    "publishArgs": ["--no-git-checks"],
    "publish": true,
    "skipChecks": true
  }
}
