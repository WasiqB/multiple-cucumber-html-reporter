{
  "name": "mchr",
  "version": "3.10.0",
  "description": "Generate beautiful Cucumber.js reports for multiple instances (browsers / devices)",
  "type": "module",
  "keywords": [
    "cucumber",
    "html",
    "test report",
    "multiple-cucumber-html-reporter",
    "html report",
    "json to html"
  ],
  "license": "MIT",
  "scripts": {
    "lint": "biome lint",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint:fix": "biome lint --write",
    "prepare": "husky",
    "release": "release-it",
    "release.ci": "pnpm release --ci",
    "beta": "pnpm release.ci --preRelease=beta",
    "release.patch": "pnpm release.ci patch",
    "release.minor": "pnpm release.ci minor",
    "release.major": "pnpm release.ci major",
    "release.premajor": "pnpm beta premajor",
    "release.preminor": "pnpm beta preminor",
    "release.prepatch": "pnpm beta prepatch"
  },
  "author": "Wasiq Bhamla",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@release-it-plugins/lerna-changelog": "^8.0.1",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lerna-changelog": "^2.2.0",
    "lint-staged": "^17.0.7",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "**/*.{ts,js,mjs,json}": [
      "pnpm format:fix",
      "pnpm format",
      "pnpm lint:fix",
      "pnpm lint"
    ]
  },
  "packageManager": "pnpm@11.5.0"
}
