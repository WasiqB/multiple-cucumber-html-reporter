{
  "name": "mchr",
  "version": "3.10.0",
  "description": "Generate beautiful Cucumber.js reports for multiple instances (browsers / devices)",
  "type": "module",
  "keywords": [
    "cucumber",
    "html",
    "test report",
    "multiple-cucumber-html-reporter",
    "html report",
    "json to html"
  ],
  "license": "MIT",
  "scripts": {
    "lint": "biome lint",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint:fix": "biome lint --write",
    "prepare": "husky"
  },
  "author": "WasiqB",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "**/*.{ts,js,mjs,json}": [
      "pnpm format:fix",
      "pnpm format",
      "pnpm lint:fix",
      "pnpm lint"
    ]
  },
  "packageManager": "pnpm@11.3.0"
}
